{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "goasm",
      "camelcase": "GoASM",
      "title": "Go Assembly",
      "scope": "source.goasm",
      "file-types": [
        "goasm"
      ],
      "injection-regex": "^goasm$",
      "class-name": "TreeSitterGoasm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "Apache-2.0",
    "description": "Goasm grammar for tree-sitter",
    "authors": [
      {
        "name": "zchee",
        "email": "zchee.io@gmail.com",
        "url": "https://github.com/zchee"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-goasm",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": true
  }
}